# ==========================================
# GERAL E SUPABASE
# ==========================================
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL=postgresql://postgres.xxx:senha@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=postgresql://postgres.xxx:senha@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ==========================================
# BACKEND (DJANGO & CELERY)
# ==========================================
DJANGO_SECRET_KEY=sua-chave-secreta-aqui
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=seu-dominio.com,localhost
CORS_ALLOWED_ORIGINS=https://seu-dominio.com,http://localhost:5173
SECURE_SSL_REDIRECT=True
LOG_LEVEL=INFO

REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/1

# ==========================================
# FRONTEND (VITE/REACT)
# ==========================================
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...
VITE_API_URL=https://api.seu-dominio.com
PORT=5173
NODE_ENV=production

# ==========================================
# INTEGRAÇÕES E IA
# ==========================================
GEMINI_API_KEY=sua-chave-gemini
GOOGLE_MAPS_PLATFORM_KEY=sua-chave-maps

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://evo.seu-dominio.com
EVOLUTION_API_KEY=sua-global-api-key
EVOLUTION_INSTANCE_NAME=sua-instancia
EVOLUTION_INSTANCE_TOKEN=seu-token-de-instancia

# ==========================================
# MOBILE (NEVESGO)
# ==========================================
NEVESGO_API_BASE_URL=https://api.seu-dominio.com/api/v1/
